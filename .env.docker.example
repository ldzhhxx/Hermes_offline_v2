# Optional docker-compose overrides for Hermes Offline.
# Copy to .env and change values before `docker compose up -d`.

HERMES_AGENT_HOST=0.0.0.0
HERMES_AGENT_PORT=5000
HERMES_WEBUI_HOST=0.0.0.0
HERMES_WEBUI_PORT=18789

# Required when exposing the Agent API on 0.0.0.0. Replace for production.
API_SERVER_KEY=hermes-offline-default-api-key-please-change-2026
