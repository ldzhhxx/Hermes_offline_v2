# ── 启动密钥门禁 ────────────────────────────────────────────────────────────
# 必填：镜像内预置的启动密钥（build 阶段烘焙进镜像）。
# 运行容器时必须通过 -e HERMES_LAUNCH_KEY=<同一个值> 才能启动。
# 与 API_SERVER_KEY（Agent API 访问鉴权）完全独立，用途不同，请勿混淆。
# 示例：HERMES_LAUNCH_KEY_REQUIRED=my-secret-launch-key-2026
HERMES_LAUNCH_KEY_REQUIRED=

# 必填：Yice API Key
YICE_API_KEY=

# 可选：Hermes API Server 访问密钥
# 留空时会回退到容器启动脚本里的默认值；如需自定义，再取消注释并填写。
# API_SERVER_KEY=your-api-server-key

# 常用 WebUI / API 配置
# HERMES_AGENT_HOST=0.0.0.0
# HERMES_AGENT_PORT=5000
# HERMES_WEBUI_HOST=0.0.0.0
# HERMES_WEBUI_PORT=18789
# HERMES_WEBUI_SKIP_ONBOARDING=1
# HERMES_WEBUI_DEFAULT_WORKSPACE=/home/hermes/workspace

# 常用 Hermes 开关
# HERMES_MAX_ITERATIONS=90
# HERMES_INFERENCE_PROVIDER=custom:yice
# HERMES_ALLOW_PRIVATE_URLS=true
# HERMES_IGNORE_RULES=1
# HERMES_IGNORE_USER_CONFIG=1

# 终端工具
# TERMINAL_CWD=/home/hermes/workspace
# TERMINAL_ENV=local
# TERMINAL_TIMEOUT=180
